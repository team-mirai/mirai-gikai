{
  "name": "@mirai-gikai/shared",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "exports": {
    "./ai/models": {
      "types": "./src/ai/models.ts",
      "default": "./src/ai/models.ts"
    },
    "./stream/inject-json-fields": {
      "types": "./src/stream/inject-json-fields.ts",
      "default": "./src/stream/inject-json-fields.ts"
    },
    "./moderation/build-prompt": {
      "types": "./src/moderation/build-moderation-prompt.ts",
      "default": "./src/moderation/build-moderation-prompt.ts"
